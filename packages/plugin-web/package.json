{
  "name": "@hold-rein/plugin-web",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --emitDeclarationOnly && vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ant-design/icons": "6.2.5",
    "antd": "6.4.3",
    "react": "19.2.6",
    "typebox": "1.1.38"
  },
  "devDependencies": {
    "@types/react": "19.2.15",
    "vite": "6.3.5"
  }
}
