{
  "name": "@hold-rein/cli",
  "version": "0.0.15",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "hold-rein": "./dist/cli.js",
    "hr": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "github",
    "url": "https://github.com/Mingbing-get/holdRein"
  },
  "homepage": "https://hr.myapping.cn",
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "bin": {
      "hold-rein": "./dist/cli.js",
      "hr": "./dist/cli.js"
    }
  },
  "scripts": {
    "build": "pnpm --filter @hold-rein/plugin-server build && pnpm --filter @hold-rein/api build && pnpm --filter @hold-rein/web build && tsc -p tsconfig.json --emitDeclarationOnly && vite build && node scripts/copy-runtime.mjs",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "0.75.4",
    "@earendil-works/pi-ai": "0.76.0",
    "@hold-rein/plugin-server": "workspace:^",
    "better-sqlite3": "12.10.0",
    "chalk": "^5.6.2",
    "drizzle-orm": "0.45.2",
    "express": "5.2.1",
    "cron-parser": "^5.6.1",
    "node-cron": "^4.6.0"
  },
  "devDependencies": {
    "vite": "6.3.5"
  }
}
